<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Instructions -->
    <TextView
        android:id="@+id/instructions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:layout_marginBottom="24dp" />

    <!-- Setup buttons -->
    <Button
        android:id="@+id/openSettingsBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Open Accessibility Settings"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/overlayPermBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Allow Display Over Other Apps"
        android:layout_marginBottom="28dp" />

    <!-- ─── Granite model file pickers ─────────────────────────────────── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="On-device Granite models (R1 cycles these)"
        android:textStyle="bold"
        android:textSize="15sp"
        android:layout_marginBottom="12dp" />

    <!-- Slot 1: Granite 4.1:3b -->
    <TextView
        android:id="@+id/slot1StatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="4dp" />
    <Button
        android:id="@+id/slot1PickBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Choose file... (Granite 4.1:3b)"
        android:layout_marginBottom="16dp" />

    <!-- Slot 2: Granite 4:micro -->
    <TextView
        android:id="@+id/slot2StatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="4dp" />
    <Button
        android:id="@+id/slot2PickBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Choose file... (Granite 4:micro)"
        android:layout_marginBottom="16dp" />

    <!-- Slot 3: Granite 4:1b -->
    <TextView
        android:id="@+id/slot3StatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="4dp" />
    <Button
        android:id="@+id/slot3PickBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Choose file... (Granite 4:1b)"
        android:layout_marginBottom="20dp" />

    <!-- LLM on/off toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="28dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Granite tooltip enabled (L1 toggles)"
            android:textStyle="bold" />

        <Switch
            android:id="@+id/llmEnabledSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- ─── Prompt suffixes ──────────────────────────────────────────── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Explanation prompt (Start button + long-press tooltip):"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/explanationSuffixField"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/saveExplanationBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Scenario prompt (manual / future use):"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/scenarioSuffixField"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/saveScenarioBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save"
        android:layout_marginBottom="24dp" />

    <!-- Debug mode -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Debug mode (show unmapped keycodes)"
            android:textStyle="bold" />

        <Switch
            android:id="@+id/debugSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

</LinearLayout>
</ScrollView>
