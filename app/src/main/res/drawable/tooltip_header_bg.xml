<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#232328" />
    <!-- Only round the top corners to sit flush under the card's rounded
         outer edge; bottom stays square against the body below it. -->
